PORT=8080

# Downstream service URLs (local dev defaults)
INTERVIEW_SERVICE_URL=http://localhost:3001
IDENTITY_SERVICE_URL=http://localhost:3002
PROFILE_SERVICE_URL=http://localhost:3003
JOB_SERVICE_URL=http://localhost:3004
APPLICATION_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006
BILLING_SERVICE_URL=http://localhost:3007

# Must match identity-service JWT_SECRET (used to decode Bearer tokens on proxied routes)
JWT_SECRET=dev-secret-change-me

# --- Phase 8 (optional) ---
# OpenTelemetry export to Jaeger (start with: docker compose up -d jaeger)
# OTLP HTTP endpoint — our observability package appends /v1/traces automatically
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
