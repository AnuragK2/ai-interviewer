PORT=3005
SERVICE_NAME=application-service

# Postgres — applications DB (also used read/write by matching-service)
# Docker Compose: postgresql://platform:platform@localhost:5433/platform
# Or separate DB name on same host:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interviewer_applications

# Must match identity-service / gateway JWT_SECRET
JWT_SECRET=dev-secret-change-me

NATS_URL=nats://localhost:4222

# Gateway base URL — used when applying to jobs (fetch job + profile snapshots)
GATEWAY_URL=http://localhost:8080

# Direct interview-service URL for invite flow (creates interview record)
INTERVIEW_SERVICE_URL=http://localhost:3001
PROFILE_SERVICE_URL=http://localhost:3003
JOB_SERVICE_URL=http://localhost:3004

# Links inside in-app notifications / emails
FRONTEND_URL=http://localhost:5173

# Shared secret for job-service → POST /api/v1/internal/tenant-audit
# Must match INTERNAL_SERVICE_KEY in job-service
INTERNAL_SERVICE_KEY=dev-internal-service-key

# Billing entitlement + interview invite usage metering
BILLING_SERVICE_URL=http://localhost:3007

# --- Phase 8 (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
