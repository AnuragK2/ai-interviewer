generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  SUBMITTED
  ANALYZING
  ANALYZED
  INTERVIEW_INVITED
  INTERVIEW_PENDING
  INTERVIEW_IN_PROGRESS
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
}

model Application {
  id              String            @id @default(uuid())
  jobId           String
  companyId       String
  candidateUserId String

  coverLetter     String?
  status          ApplicationStatus @default(SUBMITTED)

  /** Snapshots at the time of apply (for deterministic matching later). */
  jobSnapshot       Json
  candidateSnapshot Json

  /** Matching output (Phase 4). */
  fitScore      Int?
  fitSummary    String?
  strengths     String[] @default([])
  concerns      String[] @default([])
  analyzedAt    DateTime?

  /** Interview invite (Phase 5). */
  interviewId   String?
  invitedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([jobId])
  @@index([companyId])
  @@index([candidateUserId])
  @@index([interviewId])
  @@unique([jobId, candidateUserId])
}

model ProcessedEvent {
  id           String   @id @default(uuid())
  consumerName String
  eventId      String
  subject      String
  processedAt  DateTime @default(now())

  @@unique([consumerName, eventId])
  @@index([processedAt])
}

model TenantAuditLog {
  id           String   @id @default(uuid())
  companyId    String
  actorUserId  String
  actorEmail   String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
}
