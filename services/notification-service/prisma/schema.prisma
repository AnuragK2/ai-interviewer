generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

model ProcessedEvent {
  id           String   @id @default(uuid())
  consumerName String
  eventId      String
  subject      String
  processedAt  DateTime @default(now())

  @@unique([consumerName, eventId])
  @@index([processedAt])
}
