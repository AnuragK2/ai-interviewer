generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  SUBMITTED
  ANALYZING
  ANALYZED
  INTERVIEW_INVITED
  INTERVIEW_PENDING
  INTERVIEW_IN_PROGRESS
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
}

model Application {
  id              String            @id
  jobId           String
  companyId       String
  candidateUserId String

  coverLetter     String?
  status          ApplicationStatus

  jobSnapshot       Json
  candidateSnapshot Json

  fitScore      Int?
  fitSummary    String?
  strengths     String[]
  concerns      String[]
  analyzedAt    DateTime?

  interviewId   String?
  invitedAt     DateTime?

  createdAt     DateTime
  updatedAt     DateTime

  @@index([jobId])
  @@index([companyId])
  @@index([candidateUserId])
  @@index([interviewId])
  @@unique([jobId, candidateUserId])
}
