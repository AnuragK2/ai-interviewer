generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Shares the `ai_interviewer_applications` database with application-service.
/// Run `bun run db:migrate` only in application-service; here use `bun run db:generate`.

enum ApplicationStatus {
  SUBMITTED
  ANALYZING
  ANALYZED
  INTERVIEW_INVITED
  INTERVIEW_PENDING
  INTERVIEW_IN_PROGRESS
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
}

model Application {
  id              String            @id
  jobId           String
  companyId       String
  candidateUserId String

  coverLetter     String?
  status          ApplicationStatus

  jobSnapshot       Json
  candidateSnapshot Json

  fitScore      Int?
  fitSummary    String?
  strengths     String[]
  concerns      String[]
  analyzedAt    DateTime?

  interviewId   String?
  invitedAt     DateTime?

  createdAt     DateTime
  updatedAt     DateTime

  @@index([jobId])
  @@index([companyId])
  @@index([candidateUserId])
  @@index([interviewId])
  @@unique([jobId, candidateUserId])
}

model ProcessedEvent {
  id           String   @id @default(uuid())
  consumerName String
  eventId      String
  subject      String
  processedAt  DateTime @default(now())

  @@unique([consumerName, eventId])
  @@index([processedAt])
}
