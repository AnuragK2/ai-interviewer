PORT=3001
SERVICE_NAME=interview-service

# Local Postgres
DATABASE_URL=your_database_url_here

# Docker Compose alternative:
# DATABASE_URL=postgresql://platform:platform@localhost:5433/platform

OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Realtime (optional)
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=marin

# GitHub enrichment (optional)
# GITHUB_TOKEN=your_github_token_here
# PROXY_URL=your_proxy_url_here

# NATS event bus (docker-compose)
NATS_URL=nats://localhost:4222

# MinIO object storage (docker-compose) — recordings, resumes, proctoring snapshots
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=platform-media
