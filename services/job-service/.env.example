PORT=3004
SERVICE_NAME=job-service

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interviewer_jobs

# Must match identity-service / gateway JWT_SECRET
JWT_SECRET=dev-secret-change-me

# Gateway — used by GET /api/v1/jobs/_candidate/recommended (fetches profile + applications)
GATEWAY_URL=http://localhost:8080

# Application-service direct URL — used to write tenant audit logs (not via gateway)
APPLICATION_SERVICE_URL=http://localhost:3005

# Must match INTERNAL_SERVICE_KEY in application-service
INTERNAL_SERVICE_KEY=dev-internal-service-key

# Billing entitlement checks (interview invites gated by plan limits)
BILLING_SERVICE_URL=http://localhost:3007

# Optional — enables AI-generated job descriptions (falls back to template when unset)
OPENAI_API_KEY=
