PORT=3007
SERVICE_NAME=billing-service

# Postgres — billing DB
# Docker Compose: postgresql://platform:platform@localhost:5433/platform
DATABASE_URL=postgresql://platform:platform@localhost:5433/platform

# Must match identity-service / gateway JWT_SECRET
JWT_SECRET=dev-secret-change-me

# Must match INTERNAL_SERVICE_KEY in job-service / application-service / identity-service
INTERNAL_SERVICE_KEY=dev-internal-service-key

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional — override Razorpay plan IDs created in dashboard (tier_interval)
# RAZORPAY_PLAN_PRO_MONTHLY=
# RAZORPAY_PLAN_PRO_QUARTERLY=
# RAZORPAY_PLAN_PRO_YEARLY=
# RAZORPAY_PLAN_BUSINESS_MONTHLY=
# RAZORPAY_PLAN_BUSINESS_QUARTERLY=
# RAZORPAY_PLAN_BUSINESS_YEARLY=
