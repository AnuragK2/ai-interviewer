PORT=3002
SERVICE_NAME=identity-service

# Separate DB from interview-service (each service owns its own migrations)
DATABASE_URL=your_database_url_here
# Docker Compose alternative:
# DATABASE_URL=postgresql://platform:platform@localhost:5433/platform

JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
OAUTH_CALLBACK_BASE_URL=http://localhost:8080/api/v1/auth/oauth

# Google (Gmail) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

NATS_URL=nats://localhost:4222
